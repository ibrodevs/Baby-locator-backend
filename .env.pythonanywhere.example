DJANGO_SECRET_KEY=replace-with-a-long-random-secret
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=baby-locator.online,www.baby-locator.online
DJANGO_CORS_ALLOW_ALL_ORIGINS=False
DJANGO_CSRF_TRUSTED_ORIGINS=https://yourusername.pythonanywhere.com
DJANGO_SECURE_SSL_REDIRECT=True
DJANGO_SECURE_HSTS_SECONDS=31536000
DJANGO_SECURE_HSTS_INCLUDE_SUBDOMAINS=True
DJANGO_SECURE_HSTS_PRELOAD=True
DJANGO_DB_ENGINE=django.db.backends.postgresql
DJANGO_DB_NAME=babydb
DJANGO_DB_USER=babyuser
DJANGO_DB_PASSWORD=replace-with-db-password
DJANGO_DB_HOST=localhost
DJANGO_DB_PORT=5432
REVENUECAT_WEBHOOK_AUTH_HEADER=Bearer replace-with-long-random-revenuecat-webhook-secret
REVENUECAT_ENTITLEMENT_ID=family_security_pro
# For Google Play + RevenueCat base plans, include both the short ids and the
# Play-style imported ids if needed.
REVENUECAT_PREMIUM_PRODUCT_IDS=monthly,yearly,family_security_pro:monthly,family_security_pro:yearly
REVENUECAT_LIFETIME_PRODUCT_IDS=
